# Copy to worker.env and fill in. Same Mongo the dashboard uses.
MONGODB_URI=
# Cosine merge threshold — calibrate with a labeled multi-person set before trusting counts.
THRESHOLD=0.40
# Cluster representative: "centroid" (running mean, fewer over-counts) or "best".
REPRESENTATIVE=centroid
# Fold fragment clusters smaller than this fraction of the largest into the
# nearest large cluster (0 = report raw cluster count). Calibrated: 7 -> 3.
MERGE_MIN_LARGE_FRAC=0.35
MERGE_COS=0.20
# Drop faces below this FrontFaceScore (quality gate).
MIN_QUALITY=0.50
# Rolling dedup window (days) + biometric purge horizon.
RETENTION_DAYS=3
POLL_SECONDS=5
BATCH=200
