# Copy to worker.env and fill in. Same Mongo the dashboard uses.
MONGODB_URI=
# Cosine merge threshold — calibrate with a labeled multi-person set before trusting counts.
THRESHOLD=0.50
# Drop faces below this FrontFaceScore (quality gate).
MIN_QUALITY=0.50
# Rolling dedup window (days) + biometric purge horizon.
RETENTION_DAYS=3
POLL_SECONDS=5
BATCH=200
